# Copy to .env.local and fill in. Without RESEND_API_KEY the inquiry form
# gracefully falls back to a mailto: handoff, so the page works either way.

# Resend API key — https://resend.com (free tier). Server-side only.
RESEND_API_KEY=

# Where inquiries are delivered (defaults to brookeganster75@gmail.com).
INQUIRY_TO=brookeganster75@gmail.com

# Sender. Must be on a domain verified in Resend (tomlaroc.com).
# Until the domain is verified you can use: Tom Laroc <onboarding@resend.dev>
INQUIRY_FROM=Tom Laroc <inquiries@tomlaroc.com>

# Public site URL — used for SEO canonical URLs, sitemap, OG tags, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://tomlaroc.com

# --- Supabase (Tom's OWN FREE project — not shared, $0, no card required) ---
# The free tier (500MB DB) is far more than a lead/subscriber list needs.
# Create a free project at supabase.com, run supabase/schema.sql in the SQL
# Editor, then paste the Project URL + service_role key here.
# Leave BOTH blank and the app uses the local file store — also $0.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard (/admin) ---
# CHANGE BOTH before going live. ADMIN_PASSWORD is what Tom types to log in;
# ADMIN_TOKEN is the opaque session-cookie value (make it long & random).
ADMIN_PASSWORD=tomhq
ADMIN_TOKEN=change-me-to-a-long-random-string
